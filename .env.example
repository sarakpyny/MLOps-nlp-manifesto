# spaCy model used for French lemmatization
SPACY_MODEL=fr_core_news_md

# Path to the raw manifestos parquet file
URL_RAW=https://minio.lab.sspcloud.fr/sny/mlops-manifesto/processed/manifestos_raw.parquet

# MLflow local tracking backend
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Registered model used by the API
MLFLOW_MODEL_NAME=manifesto_topic_model

# Stage loaded by the API: None, Staging, or Production
MLFLOW_MODEL_STAGE=None